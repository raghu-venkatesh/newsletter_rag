CHROMA_PERSIST_DIR=./newsletter_rag/data/chroma
CHROMA_COLLECTION=newsletter_chunks
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GENERATE_MODEL=llama3.2:3b
NEWSLETTER_CORPUS_DIR=./turing_newsletter
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
TOP_K_RETRIEVE=30
TOP_K_GENERATE=5
MAX_DISTANCE=2.0
USE_RERANKER=1
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
QUERY_EXPANSION=1
